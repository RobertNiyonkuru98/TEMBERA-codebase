generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Booking {
  description   String?         @db.VarChar(255)
  status        String          @db.VarChar(10)
  date          DateTime        @db.Date
  id            String          @id @db.Uuid
  user_id       String          @db.Uuid
  itinerary_id  String?         @db.Uuid
  type          String          @default("personal") @db.VarChar(20)
  Itinerary     Itinerary?      @relation(fields: [itinerary_id], references: [id])
  User          User            @relation(fields: [user_id], references: [id])
  BookingItem   BookingItem[]
  BookingMember BookingMember[]
}

model BookingItem {
  id           String    @id @db.Uuid
  itinerary_id String    @db.Uuid
  booking_id   String    @db.Uuid
  Booking      Booking   @relation(fields: [booking_id], references: [id])
  Itinerary    Itinerary @relation(fields: [itinerary_id], references: [id])

  @@unique([booking_id, itinerary_id])
}

model BookingMember {
  id         String  @id @db.Uuid
  booking_id String  @db.Uuid
  name       String  @db.VarChar(255)
  email      String? @db.VarChar(255)
  phone      String? @db.VarChar(50)
  Booking    Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)
}

model Company {
  name        String      @db.VarChar(50)
  description String?     @db.VarChar(255)
  contact     String?     @db.VarChar(50)
  id          String      @id @db.Uuid
  owner_id    String      @db.Uuid
  User        User        @relation(fields: [owner_id], references: [id])
  Itinerary   Itinerary[]
}

model Itinerary {
  title          String           @db.VarChar(50)
  activity       String?          @db.VarChar(255)
  description    String?          @db.VarChar(255)
  location       String?          @db.VarChar(255)
  date           DateTime         @db.Date
  price          Float
  id             String           @id @db.Uuid
  company_id     String           @db.Uuid
  Booking        Booking[]
  BookingItem    BookingItem[]
  Company        Company          @relation(fields: [company_id], references: [id])
  ItineraryImage ItineraryImage[]
}

model ItineraryImage {
  id           String    @id @default(uuid()) @db.Uuid
  itinerary_id String    @db.Uuid
  image_path   String?   @db.VarChar(255)
  image_url    String    @db.VarChar(500)
  public_id    String    @db.VarChar(255)
  order        Int       @default(0)
  created_at   DateTime  @default(now())
  Itinerary    Itinerary @relation(fields: [itinerary_id], references: [id], onDelete: Cascade)
}

model Role {
  id            String @id @db.Uuid
  user_id       String @db.Uuid
  access_level  String @db.VarChar(50)
  access_status String @db.VarChar(20)
  User          User   @relation(fields: [user_id], references: [id])

  @@unique([user_id, access_level])
}

model User {
  name         String    @db.VarChar(255)
  email        String    @unique @db.VarChar(255)
  phone_number String?   @db.VarChar(50)
  password     String    @db.VarChar(255)
  id           String    @id @db.Uuid
  Booking      Booking[]
  Company      Company[]
  Role         Role[]
}
